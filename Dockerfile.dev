FROM node:20-alpine

# OpenSSL wird von Prisma benötigt
RUN apk add --no-cache openssl

WORKDIR /app

# Abhängigkeiten zuerst installieren (besseres Layer-Caching)
COPY package*.json ./
RUN npm install

# Quellcode kopieren
COPY . .

# Ports für Next.js und Prisma Studio
EXPOSE 3000
EXPOSE 5555

CMD ["npm", "run", "dev"]
