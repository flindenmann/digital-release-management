# ─── Datenbank ────────────────────────────────────────────────────────────────
# Lokal (Docker): postgresql://drm:drm@localhost:5432/drm
# Im Docker-Netzwerk (app-Service): postgresql://drm:drm@db:5432/drm
DATABASE_URL="postgresql://user:pass@localhost:5432/drm"

# ─── NextAuth.js ──────────────────────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
# Generieren mit: openssl rand -base64 32
NEXTAUTH_SECRET="CHANGE_ME_generate_with_openssl_rand_base64_32"

# ─── Supabase (nur für gehostetes Setup, leer lassen bei on-premise) ──────────
NEXT_PUBLIC_SUPABASE_URL="https://xxx.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."

# ─── Realtime ─────────────────────────────────────────────────────────────────
# true  = Supabase Realtime (gehostet)
# false = Polling-Fallback alle 10 Sekunden (on-premise / Docker)
REALTIME_ENABLED="true"

# ─── File Storage ─────────────────────────────────────────────────────────────
# Supabase (gehostet): https://xxx.supabase.co/storage/v1
# On-premise (MinIO):  http://localhost:9000
STORAGE_ENDPOINT="https://xxx.supabase.co/storage/v1"
STORAGE_BUCKET="drm-attachments"

# ─── MinIO (nur on-premise) ───────────────────────────────────────────────────
MINIO_ACCESS_KEY="minioadmin"
MINIO_SECRET_KEY="minioadmin"

# ─── Logging ──────────────────────────────────────────────────────────────────
# debug | info | warn | error
LOG_LEVEL="info"
